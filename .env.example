# MongoDB Configurations
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=managementAgencyDB
MONGO_COLLECTION=conversations

# OpenAI API Settings
OPENAI_API_KEY=your_openai_api_key_here
PRIMARY_MODEL=gpt-4o
FALLBACK_MODEL=gpt-4o-mini

# Unipile Gateway Config
UNIPILE_API_KEY=your_unipile_api_key_here
UNIPILE_API_URL=https://api.unipile.com/v1

# Calendly Event Routing Links
CALENDLY_INTAKE_URL=https://calendly.com/bhmanagement/intake-call-beerthuizen-management
CALENDLY_PHOTO_URL=https://calendly.com/bhmanagement/fotostudio-huren
CALENDLY_PODCAST_URL=https://calendly.com/bhmanagement/podcast-opnemen

# Manual Takeover / Alert Email settings
EMIRHAN_EMAIL=emirhan@beerthuizenmanagement.nl
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_sender_email@gmail.com
SMTP_PASSWORD=your_app_password
